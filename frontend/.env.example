# frontend 환경변수 샘플 — 실제 값은 .env에 넣으세요 (.env는 gitignore됨)
# 사용법: 이 파일을 복사해 .env로 만들고 각 placeholder를 실제 값으로 교체

# ─── DB (Supabase PostgreSQL) ───
# 마이그레이션(prisma push/pull)은 세션 pooler 5432, 런타임 INSERT는 6543
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ─── AI 이미지 검증 (Gemini → OpenAI → Anthropic 순 폴백, 최소 1개) ───
GEMINI_API_KEY="AIza..."          # 기본·무료 (현재 데모는 이것만으로 동작)
OPENAI_API_KEY="sk-..."           # 선택·폴백
ANTHROPIC_API_KEY="sk-ant-..."    # 선택·폴백

# ─── 내부 API 호출 / 데모 모드 ───
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
DEMO_MODE="live"                  # live | cached

# ─── 온체인 (Polygon Amoy 테스트넷) ───
NEXT_PUBLIC_AMOY_RPC="https://rpc-amoy.polygon.technology"
PRIVATE_KEY="0x..."               # 서버 지갑(=배포자=VERIFIER) 키. 테스트넷 전용 버리는 키
FARM_TOKEN_ADDRESS=""             # 배포 후 채움
ESCROW_ADDRESS=""                 # 배포 후 채움
