# frontend 환경변수 샘플 — 실제 값은 .env에 넣으세요 (.env는 gitignore됨)
# 사용법: 이 파일을 복사해 .env로 만들고 각 placeholder를 실제 값으로 교체

# ─── DB (Supabase PostgreSQL) ───
# 마이그레이션(prisma push, DDL)은 세션 pooler 5432, 런타임/시드(DML)는 6543
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres"

# ─── 세션 (이메일+비밀번호 로그인 JWT 서명) ───
# 32바이트 랜덤 hex 권장: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="교체하세요_랜덤32바이트hex"
