generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 사용자 ───
model User {
  id           String   @id @default(cuid())
  name         String
  role         String   // landlord, operator, admin
  email        String?  @unique
  passwordHash String?  // 이메일+비밀번호 로그인 (bcrypt 해시)
  createdAt    DateTime @default(now())
  spaces               Space[]
  operatorApplications OperatorApplication[]
}

// ─── 운영자 지원 신청 ───
model OperatorApplication {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  region         String   // 희망 운영 지역
  cropExperience String   // 작물 재배 경험
  availableHours String   // 주간 투입 가능 시간
  status         String   @default("applied") // applied → docs → education → matched → operating
  createdAt      DateTime @default(now())
}

// ─── 유휴공간 등록 ───
model Space {
  id               String   @id @default(cuid())
  ownerId          String?
  owner            User?    @relation(fields: [ownerId], references: [id])
  spaceType        String   // rooftop, vacant_store, indoor
  address          String
  area             String   // ~50평, 50~100평 등 구간 문자열
  electricity      String   // 전기 가능/부분 가능 등
  water            String   // 수도 가능/부분 가능 등
  lighting         String   // 채광 조건: 매우 좋음/좋음/보통/낮음
  preferredMode    String   // 임대형, 수익 공유형, 협의 가능
  photos           String[] // Supabase Storage URL 목록
  suitabilityScore Int?     // 스마트팜 적합도 (%)
  estimatedRent    Int?     // 예상 월 임대 수익 (원)
  status           String   @default("submitted") // submitted, reviewing, approved, rejected
  createdAt        DateTime @default(now())
}

// ─── 지점 (모델명 Project 유지, 도메인 표기는 '지점') ───
model Project {
  id            String       @id @default(cuid())
  name          String
  description   String?
  location      String?
  buildingType  String?
  areaSqm       Float?
  status        String       @default("operating") // operating, paused, closed
  imageUrl      String?
  institutionId String?      // 도입 기관 (성과 리포트 집계 단위)
  institution   Institution? @relation(fields: [institutionId], references: [id])
  createdAt     DateTime     @default(now())
  iotData        IotData[]
  inventories    Inventory[]
  harvestRecords HarvestRecord[]
  salesRecords   SalesRecord[]
}

// ─── IoT 데이터 ───
model IotData {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  temperature    Float
  humidity       Float
  co2Level       Float
  lightIntensity Float
  phLevel        Float
  growthRate     Float    @default(0)
  anomalyScore   Float    @default(0)
  isAnomaly      Boolean  @default(false)
  recordedAt     DateTime @default(now())

  @@index([projectId, recordedAt])
}

// ─── 알림 (생육 이상 알림) ───
model Notification {
  id          String   @id @default(cuid())
  projectId   String?  // 발생 지점
  type        String   // anomaly_detected
  message     String
  evidenceUrl String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── 도입 기관 (공공·대학·ESG 기업) — 성과 리포트 소유자 ───
model Institution {
  id           String    @id @default(cuid())
  name         String
  type         String    // public, university, esg_company
  contactName  String?
  contactEmail String?
  createdAt    DateTime  @default(now())
  projects     Project[]
}

// ─── 품목 마스터 (재배·판매 대상 작물) ───
model Product {
  id        String   @id @default(cuid())
  name      String   // 상추, 루꼴라, 바질
  category  String   // leafy, herb
  unit      String   @default("봉")
  unitPrice Int      // 판매단가 (원)
  growDays  Int      // 파종~수확 재배일수
  createdAt DateTime @default(now())
  inventories    Inventory[]
  harvestRecords HarvestRecord[]
  salesRecords   SalesRecord[]
}

// ─── 재고-생육 (지점×품목 현재 상태) — '오늘 할 일' 집계 원천 ───
model Inventory {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id])
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  inStock           Int       @default(0) // 매장 진열 재고 (봉)
  growing           Int       @default(0) // 재배중 수량 (봉)
  plantedAt         DateTime? // 파종일
  expectedHarvestAt DateTime? // 예상 수확일
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, productId])
}

// ─── 수확 실적 (생산량 집계 — 검증 필드 없음) ───
model HarvestRecord {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      // 수확량 (봉)
  harvestedAt DateTime @default(now())

  @@index([projectId, harvestedAt])
}

// ─── 판매 실적 (운영자 수기입력 — 판매-재배 연동 원천) ───
model SalesRecord {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      // 판매 수량 (봉)
  amount    Int      // 매출 (원)
  soldAt    DateTime @default(now())

  @@index([projectId, soldAt])
}
