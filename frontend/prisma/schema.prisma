generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 사용자 ───
model User {
  id           String   @id @default(cuid())
  name         String
  role         String   // investor, landlord, operator, admin
  email        String?  @unique
  passwordHash String?  // 이메일+비밀번호 로그인 (bcrypt 해시)
  walletAddress String? @unique // 투자(청약) 시 연결하는 지갑 주소
  nonce        String?  // 지갑 연결 서명 챌린지 nonce
  balance      BigInt   @default(0) // 원화 잔액 (모의)
  // ─── 신원 인증 / KYC (OpenDID 모바일 신분증 연동) ───
  identityVerified    Boolean   @default(false) // 실명 인증 완료 여부
  verifiedAt          DateTime? // 인증 완료 시각
  realName            String?   // 검증된 실명
  birthDate           DateTime? // 생년월일 (적격투자 연령 판단)
  investorAnnualLimit BigInt?   // 연간 투자한도 (원 단위, 자본시장법 룰엔진 산출)
  businessRegNo       String?   // 사업자등록번호 (건물주/운영자)
  createdAt    DateTime @default(now())
  transactions          Transaction[]
  tokenHoldings         TokenHolding[]
  dividendClaims        DividendClaim[]
  spaces                Space[]
  operatorApplications  OperatorApplication[]
  identityVerifications IdentityVerification[]
}

// ─── 운영자 지원 신청 ───
model OperatorApplication {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  region         String   // 희망 운영 지역
  cropExperience String   // 작물 재배 경험
  availableHours String   // 주간 투입 가능 시간
  status         String   @default("applied") // applied → docs → education → matched → operating
  createdAt      DateTime @default(now())
}

// ─── 신원 인증 세션 (OpenDID Verifier 흐름 — 모바일 신분증) ───
model IdentityVerification {
  id        String   @id @default(cuid())
  userId    String?  // 로그인 전 세션도 허용 (익명 → 인증 후 연결)
  user      User?    @relation(fields: [userId], references: [id])
  txId      String   @unique // Verifier 트랜잭션 ID (request-offer-qr)
  status    String   @default("pending") // pending → submitted → verified → failed
  claims    Json?    // confirm-verify로 받은 검증 클레임
  createdAt DateTime @default(now())
}

// ─── 유휴공간 등록 ───
model Space {
  id               String   @id @default(cuid())
  ownerId          String?
  owner            User?    @relation(fields: [ownerId], references: [id])
  spaceType        String   // rooftop, vacant_store, indoor
  address          String
  area             String   // ~50평, 50~100평 등 구간 문자열
  electricity      String   // 전기 가능/부분 가능 등
  water            String   // 수도 가능/부분 가능 등
  lighting         String   // 채광 조건: 매우 좋음/좋음/보통/낮음
  preferredMode    String   // 임대형, 수익 공유형, 협의 가능
  photos           String[] // Supabase Storage URL 목록
  suitabilityScore Int?     // 스마트팜 적합도 (%)
  estimatedRent    Int?     // 예상 월 임대 수익 (원)
  status           String   @default("submitted") // submitted, reviewing, approved, rejected
  createdAt        DateTime @default(now())
}

// ─── 지점/사이트 (STO 라운드 단위이자 운영 단위) ───
model Project {
  id            String       @id @default(cuid())
  name          String
  description   String?
  location      String?
  buildingType  String?
  areaSqm       Float?
  // ─── STO 펀딩 (펀딩 전 운영 지점은 null) ───
  tokenSymbol     String?
  tokenPrice      BigInt?         // 원화 단가
  totalTokens     Int?
  soldTokens      Int             @default(0)
  targetAmount    BigInt?
  currentAmount   BigInt          @default(0)
  totalCapex      BigInt          @default(0)
  fundingStart    DateTime?
  fundingEnd      DateTime?
  contractAddress String?
  status        String       @default("operating") // upcoming, funding, funded, operating, paused, completed
  imageUrl      String?
  institutionId String?      // 도입 기관 (성과 리포트 집계 단위)
  institution   Institution? @relation(fields: [institutionId], references: [id])
  createdAt     DateTime     @default(now())
  escrow         Escrow?
  milestones     Milestone[]
  transactions   Transaction[]
  tokenHoldings  TokenHolding[]
  dividends      Dividend[]
  partners       ProjectPartner[]
  navSnapshots   NavSnapshot[]
  iotData        IotData[]
  inventories    Inventory[]
  harvestRecords HarvestRecord[]
  salesRecords   SalesRecord[]
}

// ─── 에스크로 ───
model Escrow {
  id              String  @id @default(cuid())
  projectId       String  @unique
  project         Project @relation(fields: [projectId], references: [id])
  totalLocked     BigInt  @default(0)
  totalReleased   BigInt  @default(0)
  remaining       BigInt  @default(0)
  status          String  @default("active")
  contractAddress String?
}

// ─── 마일스톤 ───
model Milestone {
  id                   String         @id @default(cuid())
  projectId            String
  project              Project        @relation(fields: [projectId], references: [id])
  seq                  Int
  name                 String
  description          String?
  releasePct           Int            // 3500 = 35%
  releaseAmount        BigInt         @default(0)
  status               String         @default("pending") // pending, in_progress, verified, completed, failed, manual_review
  conditionText        String?
  requiredSignals      String[]       // ["contract", "receipt", "photo", "iot"]
  iotMinDays           Int            @default(0)
  retryCount           Int            @default(0)
  crossCheck           String?
  assetValue           BigInt         @default(0)
  evidenceUrl          String?
  aiVerificationResult Json?
  completedAt          DateTime?
  notifications        Notification[]

  @@unique([projectId, seq])
}

// ─── 거래 내역 ───
model Transaction {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  userId      String?  // null = 시스템 거래 (트랜치 해제 등)
  user        User?    @relation(fields: [userId], references: [id])
  type        String   // subscription, tranche_release, dividend, revenue
  amount      BigInt
  tokenAmount Int?
  txHash      String?
  blockNumber Int?
  memo        String?
  createdAt   DateTime @default(now())
}

// ─── 토큰 보유 ───
model TokenHolding {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  amount    Int
  avgPrice  BigInt

  @@unique([userId, projectId])
}

// ─── 배당 ───
model Dividend {
  id            String          @id @default(cuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id])
  totalRevenue  BigInt
  totalDividend BigInt
  perToken      BigInt
  period        String
  createdAt     DateTime        @default(now())
  claims        DividendClaim[]
}

// ─── 배당 수령 ───
model DividendClaim {
  id          String   @id @default(cuid())
  dividendId  String
  dividend    Dividend @relation(fields: [dividendId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tokenAmount Int
  claimAmount BigInt
  claimed     Boolean  @default(false)
  claimedAt   DateTime?
}

// ─── IoT 데이터 ───
model IotData {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  temperature    Float
  humidity       Float
  co2Level       Float
  lightIntensity Float
  phLevel        Float
  growthRate     Float    @default(0)
  anomalyScore   Float    @default(0)
  isAnomaly      Boolean  @default(false)
  recordedAt     DateTime @default(now())

  @@index([projectId, recordedAt])
}

// ─── 알림 (마일스톤 검증 이벤트 + 생육 이상) ───
model Notification {
  id          String     @id @default(cuid())
  projectId   String?    // 생육 이상 발생 지점
  milestoneId String?    // STO 마일스톤 검증 이벤트
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  type        String     // verification_failed, anomaly_detected, manual_review
  message     String
  evidenceUrl String?
  isRead      Boolean    @default(false)
  createdAt   DateTime   @default(now())
}

// ─── 프로젝트 파트너 ───
model ProjectPartner {
  id                     String  @id @default(cuid())
  projectId              String
  project                Project @relation(fields: [projectId], references: [id])
  role                   String  // landlord, equipment_partner
  name                   String
  totalContribution      BigInt  @default(0)
  recoveredAmount        BigInt  @default(0)
  monthlyRecoveryAmount  BigInt  @default(0)
  recoveryComplete       Boolean @default(false)
}

// ─── NAV 스냅샷 ───
model NavSnapshot {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id])
  nav                Float
  escrowBalance      BigInt
  assetValue         BigInt
  cumulativeCashFlow BigInt
  recordedAt         DateTime @default(now())
}

// ─── AI 검증 결과 캐시 (시연 안정성용) ───
model AiCache {
  id          String   @id @default(cuid())
  milestoneId String
  signalType  String   // contract, receipt, photo
  result      Json?
  createdAt   DateTime @default(now())

  @@unique([milestoneId, signalType])
}

// ─── 데모 캐시 ───
model DemoCache {
  id          String   @id @default(cuid())
  step        Int
  signalType  String?
  txHash      String?
  blockNumber Int?
  result      Json?
  createdAt   DateTime @default(now())
}

// ─── 도입 기관 (공공·대학·ESG 기업) — 성과 리포트 소유자 ───
model Institution {
  id           String    @id @default(cuid())
  name         String
  type         String    // public, university, esg_company
  contactName  String?
  contactEmail String?
  createdAt    DateTime  @default(now())
  projects     Project[]
}

// ─── 품목 마스터 (재배·판매 대상 작물) ───
model Product {
  id        String   @id @default(cuid())
  name      String   // 상추, 루꼴라, 바질
  category  String   // leafy, herb
  unit      String   @default("봉")
  unitPrice Int      // 판매단가 (원)
  growDays  Int      // 파종~수확 재배일수
  createdAt DateTime @default(now())
  inventories    Inventory[]
  harvestRecords HarvestRecord[]
  salesRecords   SalesRecord[]
}

// ─── 재고-생육 (지점×품목 현재 상태) — '오늘 할 일' 집계 원천 ───
model Inventory {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id])
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  inStock           Int       @default(0) // 매장 진열 재고 (봉)
  growing           Int       @default(0) // 재배중 수량 (봉)
  plantedAt         DateTime? // 파종일
  expectedHarvestAt DateTime? // 예상 수확일
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, productId])
}

// ─── 수확 실적 (생산량 집계 — 검증 필드 없음) ───
model HarvestRecord {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      // 수확량 (봉)
  harvestedAt DateTime @default(now())

  @@index([projectId, harvestedAt])
}

// ─── 판매 실적 (운영자 수기입력 — 판매-재배 연동 원천) ───
model SalesRecord {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      // 판매 수량 (봉)
  amount    Int      // 매출 (원)
  soldAt    DateTime @default(now())

  @@index([projectId, soldAt])
}
